{
  "name": "@bradsjm/signalwire-admin-mcp",
  "version": "0.1.0",
  "license": "MIT",
  "author": {
    "name": "Jonathan Bradshaw",
    "email": "jb@nrgup.net"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bradsjm/signalwire-admin-mcp.git"
  },
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@11.16.0",
  "engines": {
    "node": ">=20.19.0"
  },
  "bin": {
    "signalwire-admin-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "postbuild": "node -e \"fs=require('fs');try{fs.chmodSync('dist/index.js',0o755)}catch{}\"",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "pnpm build && vitest run",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@signalwire/sdk": "2.0.5",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
